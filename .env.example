# 실 연동용 자격증명 (NFR-02: 자격증명 마스킹).
# 이 값들은 데이터 생성기(서버/CI)에서만 사용되며 클라이언트 번들에 포함되지
# 않는다. 현재 프로토타입의 생성기는 시뮬레이션 데이터를 만들며, 실 연동 시
# scripts/generate-mock.ts 의 simulate*/synthAggregate 부분을 각 제공자 API
# 어댑터로 교체하면 된다.

# Cloudflare Radar (Bearer 토큰)
CLOUDFLARE_API_TOKEN=

# M-Lab via BigQuery (서비스 계정 키 / 경로) + GCP 프로젝트 id
MLAB_BQ_KEY=
MLAB_BQ_PROJECT=

# RIPE Atlas API 키
RIPE_ATLAS_KEY=
